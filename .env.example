# LLM Provider (openai or anthropic)
MOXEN_LLM_PROVIDER=openai

# OpenAI API Key (required when using openai provider)
OPENAI_API_KEY=your-openai-api-key-here

# Soil query embeddings
# Defaults to text-embedding-3-small when OPENAI_API_KEY is available.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: set SOIL_EMBEDDING_PROVIDER=ollama to use Ollama for soil_query.
# SOIL_EMBEDDING_PROVIDER=ollama
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434

# Anthropic API Key (required when using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
